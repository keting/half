# HALF — environment configuration template
# Copy this file to .env, fill in the required values, then `docker compose up -d`.

# ===== Required =====

# JWT signing key. Generate one:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
HALF_SECRET_KEY=

# Initial admin password. Rules:
#   - at least 8 characters
#   - must contain uppercase, lowercase, and digits
#   - never use known defaults like `admin`, `example-insecure-password-placeholder`, `password`
HALF_ADMIN_PASSWORD=

# ===== Recommended =====

# Refuse to start if HALF_SECRET_KEY / HALF_ADMIN_PASSWORD look weak.
# Default: true.
HALF_STRICT_SECURITY=true

# Whether unauthenticated visitors can self-register as regular users. Default: false.
# Set to `true` only for internal demo deployments.
HALF_ALLOW_REGISTER=false

# Whether to load the built-in browsable demo project on first startup.
# Default: true. Set to `false` for production deployments that should start empty.
HALF_DEMO_SEED_ENABLED=true

# ===== Optional =====

# Comma-separated list of origins allowed for CORS.
# HALF_CORS_ORIGINS=https://half.example.com

# Path where backend SQLite DB lives (inside container). Defaults to
# /app/data/half.db via the `backend-data` named volume.
# HALF_DB_PATH=/app/data/half.db

# Path where per-project git clones live. Defaults to /app/repos via the
# `backend-repos` named volume.
# HALF_REPOS_DIR=/app/repos

# Container-side path that corresponds to the host workspace mounted by
# docker-compose.override.yml. Only relevant when you mount a workspace.
# HALF_WORKSPACE_ROOT=/workspace
